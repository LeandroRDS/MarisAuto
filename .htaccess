# ============================================
# .htaccess - UNIVERSAL (XAMPP + InfinityFree)
# ============================================

RewriteEngine On

# Detecta se está em subpasta ou raiz
RewriteCond %{REQUEST_URI}::$1 ^(.*?/)(.*)::\2$
RewriteRule ^(.*)$ - [E=BASE:%1]

# Define o RewriteBase dinamicamente
RewriteBase %{ENV:BASE}

# Se for arquivo real, não reescreve
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Regra: /usuario → perfil.php?user=usuario
RewriteRule ^([a-zA-Z0-9!@$*_-]+)$ perfil.php?user=$1 [L,QSA]